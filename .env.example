# ── App Configuration ─────────────────────────────────────────────
APP_NAME="AI Workspace OS"
ENVIRONMENT="development"
API_V1_STR="/api/v1"
SECRET_KEY="replace_this_with_a_secure_random_key_in_production"

# ── Database (PostgreSQL) ─────────────────────────────────────────
POSTGRES_PASSWORD="postgres_secure_password_dev"
POSTGRES_ASYNC_URI="postgresql+asyncpg://postgres:postgres_secure_password_dev@localhost:5432/ai_workspace_os"

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379/0"

# ── Vector Database (ChromaDB) ────────────────────────────────────
CHROMA_HOST="localhost"
CHROMA_PORT=8000

# ── LLM Provider (Groq / OpenAI) ──────────────────────────────────
# Default fallback key (optional, users can configure their own keys in the app settings)
GROQ_API_KEY="gsk_your_groq_api_key_here"

# ── Frontend ──────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:8000/api/v1"
