# App configuration
APP_NAME="AI Workspace OS"
ENVIRONMENT="development"
API_V1_STR="/api/v1"
SECRET_KEY="replace_this_with_a_secure_random_key_in_production"

# Database Configuration
# Dev Docker compose Postgres default URI
POSTGRES_ASYNC_URI="postgresql+asyncpg://postgres:postgres_secure_password_dev@localhost:5432/ai_workspace_os"

# Redis Configuration
REDIS_URL="redis://localhost:6379/0"

# Vector Database (ChromaDB)
CHROMA_HOST="localhost"
CHROMA_PORT=8000

# LLM Provider Configuration
GROQ_API_KEY="gsk_your_groq_api_key_here"
